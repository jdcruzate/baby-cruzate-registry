<p class="p1">};</p>
<p class="p2"><br></p>
<p class="p1">window.confirmClaim=async function(){</p>
<p class="p1"><span class="Apple-converted-space">  </span>if(!pending)return;</p>
<p class="p1"><span class="Apple-converted-space">  </span>if(pending.unclaim){</p>
<p class="p1"><span class="Apple-converted-space">    </span>await deleteDoc(doc(db,"claims",pending.id));</p>
<p class="p1"><span class="Apple-converted-space">    </span>showToast("Claim removed.");</p>
<p class="p1"><span class="Apple-converted-space">  </span>} else {</p>
<p class="p1"><span class="Apple-converted-space">    </span>const name=document.getElementById('claimName').value.trim();</p>
<p class="p1"><span class="Apple-converted-space">    </span>const contact=document.getElementById('claimContact').value.trim();</p>
<p class="p1"><span class="Apple-converted-space">    </span>const msg=document.getElementById('claimMsg').value.trim();</p>
<p class="p1"><span class="Apple-converted-space">    </span>if(!name||!contact){showToast("Please enter your name and contact number 💙");return;}</p>
<p class="p1"><span class="Apple-converted-space">    </span>await setDoc(doc(db,"claims",pending.id),{name,contact,msg,itemId:pending.id,createdAt:serverTimestamp()});</p>
<p class="p1"><span class="Apple-converted-space">    </span>showToast("Thank you! Item marked as claimed 💙");</p>
<p class="p1"><span class="Apple-converted-space">  </span>}</p>
<p class="p1"><span class="Apple-converted-space">  </span>closeModal();</p>
<p class="p1">};</p>
<p class="p2"><br></p>
<p class="p1">window.sendMsg=async function(){</p>
<p class="p1"><span class="Apple-converted-space">  </span>const name=document.getElementById('msgName').value.trim();</p>
<p class="p1"><span class="Apple-converted-space">  </span>const contact=document.getElementById('msgContact').value.trim();</p>
<p class="p1"><span class="Apple-converted-space">  </span>const text=document.getElementById('msgText').value.trim();</p>
<p class="p1"><span class="Apple-converted-space">  </span>if(!name||!contact||!text){showToast("Please fill in all required fields 💙");return;}</p>
<p class="p1"><span class="Apple-converted-space">  </span>const btn=document.getElementById('sendBtn');</p>
<p class="p1"><span class="Apple-converted-space">  </span>btn.disabled=true;</p>
<p class="p1"><span class="Apple-converted-space">  </span>await addDoc(collection(db,"messages"),{name,contact,text,createdAt:serverTimestamp()});</p>
<p class="p1"><span class="Apple-converted-space">  </span>document.getElementById('msgName').value='';</p>
<p class="p1"><span class="Apple-converted-space">  </span>document.getElementById('msgContact').value='';</p>
<p class="p1"><span class="Apple-converted-space">  </span>document.getElementById('msgText').value='';</p>
<p class="p1"><span class="Apple-converted-space">  </span>btn.disabled=false;</p>
<p class="p1"><span class="Apple-converted-space">  </span>showToast("Message sent! Thank you 💙");</p>
<p class="p1">};</p>
<p class="p2"><br></p>
<p class="p1">window.copyWallet=function(wallet,nameId,numId){</p>
<p class="p1"><span class="Apple-converted-space">  </span>const name=document.getElementById(nameId).textContent;</p>
<p class="p1"><span class="Apple-converted-space">  </span>const num=document.getElementById(numId).textContent;</p>
<p class="p1"><span class="Apple-converted-space">  </span>navigator.clipboard.writeText(`${wallet}\nAccount Name: ${name}\nNumber: ${num}`)</p>
<p class="p1"><span class="Apple-converted-space">    </span>.then(()=&gt;showToast(`${wallet} details copied! 💙`))</p>
<p class="p1"><span class="Apple-converted-space">    </span>.catch(()=&gt;showToast('Please copy the details manually.'));</p>
<p class="p1">};</p>
<p class="p2"><br></p>
<p class="p1">function showToast(msg){</p>
<p class="p1"><span class="Apple-converted-space">  </span>const t=document.getElementById('toast');</p>
<p class="p1"><span class="Apple-converted-space">  </span>t.textContent=msg;t.classList.add('show');</p>
<p class="p1"><span class="Apple-converted-space">  </span>setTimeout(()=&gt;t.classList.remove('show'),3000);</p>
<p class="p1">}</p>
<p class="p2"><br></p>
<p class="p1">document.getElementById('modal').addEventListener('click',e=&gt;{if(e.target===document.getElementById('modal'))closeModal();});</p>
<p class="p1">&lt;/script&gt;</p>
