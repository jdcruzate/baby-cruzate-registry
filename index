<p class="p1">let claimed={};</p>
<p class="p1">let pending=null;</p>
<p class="p2"><br></p>
<p class="p1">// Real-time listener for claims</p>
<p class="p1">onSnapshot(collection(db,"claims"), snap=&gt;{</p>
<p class="p1"><span class="Apple-converted-space">  </span>claimed={};</p>
<p class="p1"><span class="Apple-converted-space">  </span>snap.forEach(d=&gt;claimed[d.id]=d.data());</p>
<p class="p1"><span class="Apple-converted-space">  </span>renderGifts();</p>
<p class="p1">});</p>
<p class="p2"><br></p>
<p class="p1">// Real-time listener for messages</p>
<p class="p1">const msgsQ=query(collection(db,"messages"),orderBy("createdAt","desc"));</p>
<p class="p1">onSnapshot(msgsQ, snap=&gt;{</p>
<p class="p1"><span class="Apple-converted-space">  </span>const el=document.getElementById('msgList');</p>
<p class="p1"><span class="Apple-converted-space">  </span>if(snap.empty){el.innerHTML='&lt;p class="msg-empty"&gt;No messages yet — be the first to leave one. 💙&lt;/p&gt;';return;}</p>
<p class="p1"><span class="Apple-converted-space">  </span>el.innerHTML=snap.docs.map(d=&gt;{</p>
<p class="p1"><span class="Apple-converted-space">    </span>const m=d.data();</p>
<p class="p1"><span class="Apple-converted-space">    </span>const date=m.createdAt?.toDate().toLocaleDateString('en-PH',{year:'numeric',month:'long',day:'numeric'})||'';</p>
<p class="p1"><span class="Apple-converted-space">    </span>return`&lt;div class="msg-card"&gt;</p>
