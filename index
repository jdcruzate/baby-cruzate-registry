<p class="p1"><span class="Apple-converted-space">  </span>document.getElementById('giftGrid').innerHTML=gifts.map(g=&gt;{</p>
<p class="p1"><span class="Apple-converted-space">    </span>const c=claimed[g.id];</p>
<p class="p1"><span class="Apple-converted-space">    </span>return`&lt;div class="item-card${c?' is-claimed':''}"&gt;</p>
<p class="p1"><span class="Apple-converted-space">      </span>&lt;div class="item-thumb-wrap"&gt;</p>
<p class="p1"><span class="Apple-converted-space">        </span>&lt;img class="item-thumb" src="${driveImg(g.imgId)}" alt="${g.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"&gt;</p>
